{
  "name": "openclaw-connector-workspace",
  "private": true,
  "version": "0.2.1",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @openclaw/desktop",
    "dev:desktop": "npm run dev -w @openclaw/desktop",
    "dist:desktop": "npm run dist -w @openclaw/desktop",
    "dev:api": "npm run dev -w @openclaw/account-api",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "echo lint not configured yet"
  }
}
